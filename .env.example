# OpenClaw Admin Panel - Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=8080

# Admin credentials (change these!)
JWT_SECRET=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database
DB_PATH=/app/data/admin.db

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# OpenClaw bot container settings
OPENCLAW_CONTAINER=bot-openclaw-1
OPENCLAW_CONFIG_PATH=/home/claworc/.openclaw/openclaw.json
OPENCLAW_WORKSPACES_PATH=/home/claworc/.openclaw/workspaces
OPENCLAW_WORKSPACES_BACKUP_PATH=/home/claworc/.openclaw/workspaces-backup

# AnythingLLM integration (optional)
ANYTHINGLLM_URL=http://anythingllm:3001
ANYTHINGLLM_API_KEY=

# Docker containers to monitor (comma-separated)
MONITOR_CONTAINERS=bot-openclaw-1

# Host port mapping (used in docker-compose.yml)
ADMIN_PORT=8088
